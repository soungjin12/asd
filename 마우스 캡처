document.body.onclick=()=>{

renderer.domElement
.requestPointerLock();

};

document.addEventListener(
"mousemove",
e=>{

if(
document.pointerLockElement
!==renderer.domElement
)
return;

camera.rotation.y -=
e.movementX*0.002;

camera.rotation.x -=
e.movementY*0.002;

camera.rotation.x=
Math.max(
-1.4,
Math.min(
1.4,
camera.rotation.x
)
);

}
);
